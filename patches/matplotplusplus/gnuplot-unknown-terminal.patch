diff --git a/source/matplot/backend/gnuplot.cpp b/source/matplot/backend/gnuplot.cpp
index 1e4a330..e0a5b36 100644
--- a/source/matplot/backend/gnuplot.cpp
+++ b/source/matplot/backend/gnuplot.cpp
@@ -69,6 +69,21 @@ namespace matplot::backend {
             terminal_ = default_terminal_type();
         }
 
+        // When terminal is "unknown" (headless, no display), fall back to
+        // "dumb" which is always safe. pngcairo requires fonts/Pango which
+        // may crash in headless environments without proper fontconfig.
+        if (terminal_ == "unknown") {
+            terminal_ = "dumb";
+        }
+
+        // Check if gnuplot binary is actually available before opening pipe.
+        // Without this check, popen("gnuplot","w") returns a valid FILE* to a
+        // dead shell process, and subsequent writes cause SIGPIPE/segfault.
+        if (system("gnuplot --version > /dev/null 2>&1") != 0) {
+            pipe_ = nullptr;
+            return;
+        }
+
         // Open the gnuplot pipe_
         if constexpr (windows_should_persist_by_default) {
             pipe_ = POPEN("gnuplot --persist", "w");
@@ -278,6 +293,9 @@ namespace matplot::backend {
     bool gnuplot::render_data() { return flush_commands(); }
 
     bool gnuplot::flush_commands() {
+        if (!pipe_) {
+            return false;
+        }
         if constexpr (dont_let_it_close_too_fast) {
             last_flush_ = std::chrono::high_resolution_clock::now();
         }
@@ -451,7 +469,7 @@ namespace matplot::backend {
             "hpljii",   "hppj",    "imagen",  "linux",   "lua",
             "lua tikz", "mf",      "mif",     "mp",      "pbm",
             "pm",       "qms",     "regis",   "svga",    "texdraw",
