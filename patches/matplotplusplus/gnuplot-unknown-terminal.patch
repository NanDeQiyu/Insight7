+        // When terminal is "unknown" (headless, no display), try "pngcairo"
+        // first which supports full gnuplot features including pm3d/image.
+        // Fall back to "png" (libgd, fewer features) then "dumb".
+        if (terminal_ == "unknown") {
+            if (terminal_is_available("pngcairo")) {
+                terminal_ = "pngcairo";
+            } else if (terminal_is_available("png")) {
+                terminal_ = "png";
+            } else {
+                terminal_ = "dumb";
+            }
+        }
+
+        // Check if gnuplot binary is actually available before opening pipe.
+        // Without this check, popen("gnuplot","w") returns a valid FILE* to a
+        // dead shell process, and subsequent writes cause SIGPIPE/segfault.
+        if (system("gnuplot --version > /dev/null 2>&1") != 0) {
+            pipe_ = nullptr;
+            return;
+        }
+
+        // Open the gnuplot pipe_.
+        // Redirect gnuplot's stdout/stderr to /dev/null to prevent binary
+        // PNG data from leaking to the parent process's stdout.
+        // When save() sends "set output filename", gnuplot writes to the file.
         if constexpr (windows_should_persist_by_default) {
             pipe_ = POPEN("gnuplot --persist", "w");
